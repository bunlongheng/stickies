    "smoke:pages": "sh -c 'set -a && . .env.local && set +a && NODE_TLS_REJECT_UNAUTHORIZED=0 BASE_URL=http://localhost:4444 npx tsx tests/smoke-pages.ts'",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed"
