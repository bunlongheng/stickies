{
  "name": "stickies",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "stickies": "node scripts/stickies-cli.mjs",
    "predev": "node scripts/dev-banner.mjs; kill $(lsof -ti :4444) 2>/dev/null || true",
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "smoke": "sh -c 'set -a && . .env.local && set +a && NODE_TLS_REJECT_UNAUTHORIZED=0 BASE_URL=http://localhost:4444 npx tsx tests/smoke-signup.ts'",
    "smoke:images": "sh -c 'set -a && . .env.local && set +a && NODE_TLS_REJECT_UNAUTHORIZED=0 BASE_URL=http://localhost:4444 npx tsx tests/smoke-images.ts'",
    "smoke:flow": "sh -c 'set -a && . .env.local && set +a && NODE_TLS_REJECT_UNAUTHORIZED=0 BASE_URL=http://localhost:4444 npx tsx tests/smoke-user-flow.ts'",
    "smoke:pages": "sh -c 'set -a && . .env.local && set +a && NODE_TLS_REJECT_UNAUTHORIZED=0 BASE_URL=http://localhost:4444 npx tsx tests/smoke-pages.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@floating-ui/dom": "^1.7.6",
    "@heroicons/react": "^2.2.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/pg": "^8.18.0",
    "@types/prismjs": "^1.26.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "lz-string": "^1.5.0",
    "marked": "^17.0.3",
    "mermaid": "^11.13.0",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prismjs": "^1.30.0",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-simple-code-editor": "^0.14.1",
    "react-syntax-highlighter": "^16.1.1",
    "resend": "^6.9.3",
    "sax": "^1.5.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
